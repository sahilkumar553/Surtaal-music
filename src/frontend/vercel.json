{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/media/:id", "destination": "/api/media" },
    { "source": "/api/competitions/:id", "destination": "/api/competitions" },
    { "source": "/api/users/:id", "destination": "/api/users" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
